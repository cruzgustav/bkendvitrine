{
  // ============================================================
  // Configuração Cloudflare Workers para o tabackvitrine
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  //
  // IMPORTANTE: Este projeto usa @opennextjs/cloudflare que é
  // projetado para Workers (não Pages). Use `wrangler deploy`.
  // ============================================================

  "name": "bkendvitrine",
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2025-04-17",

  // Entry point do Worker (gerado pelo OpenNext)
  "main": ".open-next/worker.js",

  // Assets estáticos (HTML, CSS, JS, imagens)
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  // Variáveis de ambiente (NÃO colocar secrets aqui - usar wrangler secret)
  "vars": {
    "CORS_ALLOWED_ORIGINS": "*"
  }
}
